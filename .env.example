# Copy this file to `.env` at the repository root and fill in values.
# See README.md for how each app uses these variables.

# --- PostgreSQL ---
# Used by: migrations (`pnpm db:migrate`), job apps, pubsub-consumer when persisting rows
DATABASE_URL=postgres://user:password@localhost:5432/cloud_dashboards_demo

# --- Google Cloud Pub/Sub ---
# Full subscription resource name, e.g. projects/PROJECT_ID/subscriptions/SUBSCRIPTION_ID
# Used by: apps/pubsub-consumer
PUBSUB_SUBSCRIPTION=

# --- HTTP job endpoints (optional) ---
# If set, POST /run requires header: x-job-secret: <JOB_SECRET>
JOB_SECRET=

# Retention job: delete rows older than this many days (default in code: 90)
RETENTION_DAYS=90

# Dashboard: optional filter (tenant id) for the Next.js overview page
DASHBOARD_TENANT_ID=sammple-tenant

# Seed script (`pnpm db:seed`): defaults tenant abc123, 7 UTC days back
# SEED_TENANT_ID=abc123
# SEED_DAYS_BACK=7

# Daily metrics job: how many UTC days back to re-aggregate from raw requests (default: 7)
METRICS_LOOKBACK_DAYS=7

# --- Ports (optional) ---
# job-retention defaults to 8080, job-daily-metrics to 8081
# PORT=8080
